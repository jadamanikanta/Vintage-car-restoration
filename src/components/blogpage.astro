---
import "../css/blog.css"
---


<section class="hero">
  <div class="container">
    <h1>Restoration Stories & Insights</h1>
    <p>Expert tips, restoration journeys, and vintage automotive inspiration.</p>
  </div>
</section>

<section class="filter-bar container">
  <input type="text" placeholder="Search articles..." id="searchInput">
  <select>
    <option>All Categories</option>
    <option>Restoration</option>
    <option>Maintenance</option>
    <option>History</option>
  </select>
</section>

<section class="main container">

  <div class="blog-grid" id="blogGrid">

    
    <article class="card">
      <img src="/assets/interior.jpg" alt="">
      <div class="card-content">
        <span class="tag">Restoration</span>
        <h3>Bringing a 1967 Mustang Back to Life</h3>
        <p>Discover the full restoration journey from rusted shell to showroom beauty.</p>
        <div class="meta">
          <span>Feb 10, 2026</span>
          <a href="/blog/mustang-restoration" class="read-btn">Read More</a>
        </div>
      </div>
    </article>

    <article class="card">
      <img src="/assets/slide2.jpg" alt="">
      <div class="card-content">
        <span class="tag">Maintenance</span>
        <h3>Essential Care Tips for Classic Engines</h3>
        <p>Learn how to maintain performance and longevity for vintage engines.</p>
        <div class="meta">
          <span>Jan 28, 2026</span>
          <a href="/blog/engine-care-tips" class="read-btn">Read More</a>
        </div>
      </div>
    </article>

    <article class="card">
      <img src="/assets/footerimg.jpg" alt="">
      <div class="card-content">
        <span class="tag">History</span>
        <h3>The Golden Era of Automotive Design</h3>
        <p>Exploring craftsmanship that defined luxury cars of the 50s.</p>
        <div class="meta">
          <span>Jan 12, 2026</span>
          <a href="/blog/golden-era-design" class="read-btn">Read More</a>
        </div>
      </div>
    </article>

    <article class="card">
      <img src="/assets/feature6.jpg" alt="">
      <div class="card-content">
        <span class="tag">Restoration</span>
        <h3>Frame-Off Restoration Explained</h3>
        <p>A complete guide to the most thorough restoration process.</p>
        <div class="meta">
          <span>Dec 22, 2025</span>
          <a href="/blog/frame-off-restoration" class="read-btn">Read More</a>
        </div>
      </div>
    </article>

    <article class="card">
      <img src="/assets/interior.jpg" alt="">
      <div class="card-content">
        <span class="tag">Interior</span>
        <h3>Restoring Vintage Leather Interiors</h3>
        <p>How to preserve elegance of classic car interiors.</p>
        <div class="meta">
          <span>Dec 10, 2025</span>
          <a href="/blog/leather-interiors" class="read-btn">Read More</a>
        </div>
      </div>
    </article>

    <article class="card">
      <img src="/assets/painting.jpg" alt="">
      <div class="card-content">
        <span class="tag">Paint</span>
        <h3>Choosing Authentic Paint Colors</h3>
        <p>Matching original factory finishes for true restoration.</p>
        <div class="meta">
          <span>Nov 30, 2025</span>
          <a href="/blog/paint-colors" class="read-btn">Read More</a>
        </div>
      </div>
    </article>

    <article class="card">
      <img src="/assets/engine.jpg" alt="">
      <div class="card-content">
        <span class="tag">Engine</span>
        <h3>Rebuilding Carburetors Like a Pro</h3>
        <p>Step-by-step process to restore performance.</p>
        <div class="meta">
          <span>Nov 18, 2025</span>
          <a href="/blog/carburetor-rebuild" class="read-btn">Read More</a>
        </div>
      </div>
    </article>

    <article class="card">
      <img src="/assets/herosplit.jpg" alt="">
      <div class="card-content">
        <span class="tag">History</span>
        <h3>Iconic Classic Cars That Changed History</h3>
        <p>A look at legendary vehicles that shaped automotive culture.</p>
        <div class="meta">
          <span>Nov 05, 2025</span>
          <a href="/blog/iconic-classics" class="read-btn">Read More</a>
        </div>
      </div>
    </article>

  </div>

  <aside class="sidebar">

    <div class="widget">
      <h4>Categories</h4>
      <ul>
        <li>Restoration</li>
        <li>Maintenance</li>
        <li>History</li>
        <li>Engine</li>
        <li>Interior</li>
      </ul>
    </div>

    <div class="widget">
      <h4>Recent Posts</h4>
      <ul>
        <li>Classic Paint Techniques</li>
        <li>Engine Rebuild Guide</li>
        <li>Interior Restoration Tips</li>
        <li>Vintage Chrome Polishing</li>
      </ul>
    </div>

    <div class="widget">
      <h4>Popular Tags</h4>
      <div class="tags">
        <span>Vintage</span>
        <span>Engines</span>
        <span>Luxury</span>
        <span>Classic</span>
        <span>Restoration</span>
      </div>
    </div>

  </aside>

</section>

<section class="pagination container">
  <button>Prev</button>
  <button class="active">1</button>
  <button>2</button>
  <button>3</button>
  <button>Next</button>
</section>
