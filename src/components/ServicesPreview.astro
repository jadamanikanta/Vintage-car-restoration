---
import "../css/home.css";
---

<section class="services">
  <div class="container">
    <h2 class="section-title">Our Restoration Services</h2>
    <p class="section-subtitle">
      Bringing legendary classics back to life with precision engineering.
    </p>

    <div class="services-grid">
      <div class="service-card">
        <h3>Engine Rebuild</h3>
        <p>Complete engine disassembly, rebuild and performance tuning.</p>
      </div>

      <div class="service-card">
        <h3>Body & Paint</h3>
        <p>Factory-accurate paint matching and rust restoration.</p>
      </div>

      <div class="service-card">
        <h3>Interior Restoration</h3>
        <p>Leather upholstery, dashboard refinishing & detailing.</p>
      </div>

      <div class="service-card">
        <h3>Electrical Systems</h3>
        <p>Modern wiring upgrades while preserving vintage authenticity.</p>
      </div>
    </div>
  </div>
</section>
