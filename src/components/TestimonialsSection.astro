---
import "../css/home.css";
---

<section class="testimonials">
  <div class="container">

    <div class="section-header">
      <h2>What Our Clients Say</h2>
      <p>Real stories from passionate classic car owners.</p>
    </div>

    <div class="testimonial-slider">

      <button class="testimonial-arrow left">&#10094;</button>

      <div class="testimonial-track">

        <!-- Card 1 -->
        <div class="testimonial-card">
          <div class="testimonial-stars">★★★★★</div>
          <p class="testimonial-text">
            They brought my 1967 Mustang back to life.
          </p>
          <div class="testimonial-user">
            <div class="testimonial-icon">
  <svg viewBox="0 0 24 24" fill="currentColor">
    <path d="M12 12c2.7 0 5-2.3 5-5s-2.3-5-5-5-5 2.3-5 5 2.3 5 5 5zm0 2c-3.3 0-10 1.7-10 5v3h20v-3c0-3.3-6.7-5-10-5z"/>
  </svg>
</div>
            <div>
              <h4>James Robertson</h4>
              <span>Mustang Owner</span>
            </div>
          </div>
        </div>

        <!-- Card 2 -->
        <div class="testimonial-card">
          <div class="testimonial-stars">★★★★★</div>
          <p class="testimonial-text">
            The paint finish was absolutely flawless.
          </p>
          <div class="testimonial-user">
            <div class="testimonial-icon">MT</div>
            <div>
              <h4>Michael Thompson</h4>
              <span>Porsche Collector</span>
            </div>
          </div>
        </div>

        <!-- Card 3 -->
        <div class="testimonial-card">
          <div class="testimonial-stars">★★★★★</div>
          <p class="testimonial-text">
            Professional, transparent, and highly skilled team.
          </p>
          <div class="testimonial-user">
            <div class="testimonial-icon">AR</div>
            <div>
              <h4>Andrew Reed</h4>
              <span>Camaro Owner</span>
            </div>
          </div>
        </div>

        <!-- Card 4 -->
        <div class="testimonial-card">
          <div class="testimonial-stars">★★★★★</div>
          <p class="testimonial-text">
            My 1965 Corvette restoration was beyond expectations.
          </p>
          <div class="testimonial-user">
            <div class="testimonial-icon">DL</div>
            <div>
              <h4>David Lee</h4>
              <span>Corvette Collector</span>
            </div>
          </div>
        </div>

        <!-- Card 5 -->
        <div class="testimonial-card">
          <div class="testimonial-stars">★★★★★</div>
          <p class="testimonial-text">
            Communication was amazing throughout the process.
          </p>
          <div class="testimonial-user">
            <div class="testimonial-icon">SM</div>
            <div>
              <h4>Sarah Mitchell</h4>
              <span>Classic BMW Owner</span>
            </div>
          </div>
        </div>

      </div>

      <button class="testimonial-arrow right">&#10095;</button>

    </div>

    <div class="testimonial-dots"></div>

  </div>
</section>
