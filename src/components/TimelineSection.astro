---
import "../css/home.css";
---

<section class="timeline">
  <div class="container">
    <h2 class="section-title">Our Restoration Process</h2>

    <div class="timeline-steps">
      <div class="step">
        <span>01</span>
        <h3>Inspection</h3>
        <p>Full vehicle evaluation & cost estimation.</p>
      </div>

      <div class="step">
        <span>02</span>
        <h3>Disassembly</h3>
        <p>Careful teardown and cataloging of components.</p>
      </div>

      <div class="step">
        <span>03</span>
        <h3>Restoration</h3>
        <p>Engine, body, paint, and interior restoration.</p>
      </div>

      <div class="step">
        <span>04</span>
        <h3>Delivery</h3>
        <p>Final inspection and handover to client.</p>
      </div>
    </div>
  </div>
</section>
